{
  "name": "@termcoder/sdk",
  "version": "0.0.0",
  "description": "Typed client for the termcoder local server (HTTP + WebSocket).",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@termcoder/core": "workspace:*"
  },
  "devDependencies": {
    "@termcoder/server": "workspace:*",
    "@types/ws": "^8.5.13",
    "ws": "^8.18.0"
  }
}
