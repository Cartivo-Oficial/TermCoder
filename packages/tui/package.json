{
  "name": "@termcoder/tui",
  "version": "0.1.3",
  "description": "Ink (React) terminal UI for termcoder — ships the `term`/`termcoder` binary.",
  "license": "MIT",
  "author": "Eduardo <eduardo.wankax@gmail.com>",
  "keywords": ["ai", "agent", "coding-agent", "tui", "ink", "cli", "termcoder"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "bin": {
    "termcoder": "./dist/cli.js",
    "term": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@termcoder/core": "workspace:*",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2"
  }
}
