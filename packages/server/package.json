{
  "name": "@termcoder/server",
  "version": "0.0.0",
  "description": "Headless HTTP + WebSocket server for termcoder — ships the `termcoder-server` binary.",
  "license": "MIT",
  "author": "Eduardo <eduardo.wankax@gmail.com>",
  "keywords": ["ai", "agent", "coding-agent", "server", "websocket", "termcoder"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "termcoder-server": "./dist/serve.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/serve.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@termcoder/core": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2"
  }
}
