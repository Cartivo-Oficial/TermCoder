{
  "name": "@termcoder/desktop",
  "version": "0.8.2",
  "description": "Desktop app for termcoder — Electron shell around the local server with a React UI.",
  "license": "MIT",
  "author": "termcoder <eduardo.wankax@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cartivo-Oficial/TermCoder.git"
  },
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:web": "vite build --config vite.web.config.ts",
    "start": "electron-vite preview",
    "stage:pty": "node scripts/stage-pty.mjs",
    "package": "pnpm stage:pty && electron-vite build && electron-builder",
    "package:ci": "pnpm stage:pty && electron-vite build && electron-builder --publish never",
    "package:dir": "pnpm stage:pty && electron-vite build && electron-builder --dir",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "ai.termcoder.app",
    "productName": "termcoder",
    "artifactName": "TermCoder-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/pty/node_modules/@lydell",
        "to": "pty/node_modules/@lydell"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "TermCoder-Setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "TermCoder-Portable.${ext}"
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "maintainer": "termcoder <eduardo.wankax@gmail.com>",
      "synopsis": "AI coding agent for your terminal, in a desktop app",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.4",
    "@lezer/highlight": "^1.2.3",
    "@lydell/node-pty": "1.1.0",
    "@termcoder/core": "workspace:*",
    "@termcoder/server": "workspace:*",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "codemirror": "^6.0.2",
    "highlight.js": "^11.10.0",
    "react-icons": "^5.4.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0"
  },
  "optionalDependencies": {
    "@lydell/node-pty-darwin-arm64": "1.1.0",
    "@lydell/node-pty-darwin-x64": "1.1.0",
    "@lydell/node-pty-linux-arm64": "1.1.0",
    "@lydell/node-pty-linux-x64": "1.1.0",
    "@lydell/node-pty-win32-arm64": "1.1.0",
    "@lydell/node-pty-win32-x64": "1.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.2",
    "vite": "^5.4.11"
  }
}
